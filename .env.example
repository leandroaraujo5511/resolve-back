PORT=3000

# Origens CORS separadas por vírgula (ex.: http://localhost:5173). Vazio = reflete qualquer origem.
CORS_ORIGINS=

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=resolve
DB_SYNC=true

JWT_SECRET=
JWT_EXPIRES_IN=1d

# Token do app cidadão (diferente do painel)
JWT_CITIZEN_SECRET=
JWT_CITIZEN_EXPIRES_IN=7d

# OTP (sem SMS no MVP: código no log do servidor)
OTP_EXPIRES_MINUTES=10
OTP_LOG_CODE_IN_CONSOLE=true
OTP_RETURN_CODE_IN_RESPONSE=false

SEED_COMPANY_NAME=
SEED_ADMIN_NAME=
SEED_ADMIN_EMAIL=
SEED_ADMIN_PHONE=
SEED_ADMIN_PASSWORD=

# Cloudflare R2 (S3-compatible) — upload assinado
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Opcional: TTL da URL em segundos (padrão 300)
R2_PRESIGN_EXPIRES=300
