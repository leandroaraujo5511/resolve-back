PORT=3000

# Origens CORS separadas por vírgula (ex.: http://localhost:5173). Vazio = reflete qualquer origem.
CORS_ORIGINS=

# Banco local via Docker: npm run db:up (porta host 5434 → container 5432)
DB_HOST=localhost
DB_PORT=5434
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=resolve
DB_SYNC=true

JWT_SECRET=
# Access token do painel (curto). JWT_EXPIRES_IN mantido para compat; preferir JWT_ACCESS_EXPIRES_IN.
JWT_EXPIRES_IN=1d
JWT_ACCESS_EXPIRES_IN=15m
# Refresh token do painel (renovação em POST /auth/refresh)
JWT_REFRESH_EXPIRES_IN=7d
# Opcional: segredo distinto do access (recomendado em produção)
JWT_REFRESH_SECRET=

# Token do app cidadão (diferente do painel)
JWT_CITIZEN_SECRET=
JWT_CITIZEN_EXPIRES_IN=7d

# URL pública do painel (links em e-mails de boas-vindas / recuperação)
PANEL_APP_URL=http://localhost:5173
# Nome exibido nos e-mails
PANEL_APP_NAME=Resolve+
# Opcional: URL absoluta da logo (senão usa PANEL_APP_URL/logo_light.png)
# EMAIL_LOGO_URL=https://seu-cdn.com/logo_light.png
# Opcional: cor do botão CTA nos e-mails
# EMAIL_PRIMARY_COLOR=#1B4F8A

# Recuperação de senha do painel (link)
PASSWORD_RESET_EXPIRES_MINUTES=60
PASSWORD_RESET_MAX_PER_EMAIL_PER_HOUR=5
PASSWORD_RESET_MAX_PER_IP_PER_HOUR=20

# OTP cidadão — modo local (log / resposta dev) quando o gateway não estiver configurado
OTP_EXPIRES_MINUTES=10
OTP_LOG_CODE_IN_CONSOLE=true
OTP_RETURN_CODE_IN_RESPONSE=false

# Gateway de Comunicação (WhatsApp OTP). Com BASE_URL + API_KEY preenchidos,
# o envio/validação de OTP passa pelo gateway (send-otp / verify-otp) em vez do Postgres local.
COMMUNICATION_GATEWAY_BASE_URL=
COMMUNICATION_GATEWAY_API_KEY=
# DDI para montar o número internacional se o cadastro vier só com DDD+número (ex.: 55)
COMMUNICATION_GATEWAY_WHATSAPP_CC=55
# Opcional: nome do template WhatsApp no gateway (POST /templates, channel whatsapp).
# Se preenchido, send-otp envia template_name + variables; {{code}} e {{otp}} vêm do worker.
COMMUNICATION_GATEWAY_OTP_WHATSAPP_TEMPLATE=
# JSON opcional: variáveis extras do template (ex.: {"nome":"Resolve"}). Código OTP não incluir aqui.
COMMUNICATION_GATEWAY_OTP_TEMPLATE_VARIABLES_JSON=

SEED_COMPANY_NAME=
SEED_ADMIN_NAME=
SEED_ADMIN_EMAIL=
SEED_ADMIN_PHONE=
SEED_ADMIN_PASSWORD=

# Cloudflare R2 (S3-compatible) — upload assinado
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Opcional: TTL da URL em segundos (padrão 300)
R2_PRESIGN_EXPIRES=300

# Limites de anexos (painel / metadados)
ATTACHMENT_MAX_FILE_BYTES=10485760
ATTACHMENT_MAX_PER_BATCH=5
ATTACHMENT_MAX_PER_TICKET=20
ATTACHMENT_MAX_TOTAL_BYTES=104857600
